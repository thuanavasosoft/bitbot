# Core runtime
BOT_MODE=follow_martingale_bot
EXCHANGE_ADAPTER=binance

# Exchange credentials
API_KEY=your_exchange_api_key
API_SECRET=your_exchange_api_secret

# Binance only: set to true to use Futures testnet
IS_TESTNET=false
TESTNET_API_KEY=your_testnet_api_key
TESTNET_API_SECRET=your_testnet_api_secret

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Symbol / leverage
SYMBOL=BTCUSDT
LEVERAGE=5

# Follow martingale strategy
# Side is automatic: the bot can open either long or short based on breakout direction.
FM_SIGNAL_N=2880
FM_MAX_LEGS=5
FM_SIZE_MULTIPLIER=3
FM_TAKE_PROFIT_PCT=0.01

# Optional overrides / tuning
# If set, uses this fixed leg-1 margin instead of total-balance geometric sizing.
# FM_MARGIN_USDT=100
FM_MAINTENANCE_DISCOUNT_PCT=5
FM_BUFFER_PCT=0
FM_STOP_LOSS_PERCENT=100
FM_CANDLE_RESOLUTION=1Min
FM_LOOP_INTERVAL_MS=10000
FM_ORDER_TIMEOUT_MS=60000
